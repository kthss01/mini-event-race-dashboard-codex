{
  "name": "mini-event-race-dashboard-codex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "build:data": "tsx scripts/buildData.ts",
    "fetch:doc": "tsx scripts/fetchDoc.ts",
    "parse:doc": "tsx scripts/parseDoc.ts",
    "enrich:data": "tsx scripts/enrich.ts",
    "validate:data": "tsx scripts/validateData.ts",
    "test": "node --import tsx --test scripts/__tests__/*.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "prettier": "^3.3.3"
  }
}
